{
  "name": "@nyxtok/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "migrate": "tsx src/migrate.ts",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.js --external:pino-pretty --minify",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@nyxtok/shared": "workspace:*",
    "fastify": "^4.28.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.23.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
