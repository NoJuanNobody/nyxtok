{
  "name": "@nyxtok/discovery",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/main.js --external:@xenova/transformers --minify",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nyxtok/shared": "workspace:*",
    "node-cron": "^3.0.3",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.3",
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
