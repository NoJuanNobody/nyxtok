# ─── Nyxtok environment configuration ───────────────────────────────────────
# Copy to `.env` and fill in real values. See README.md for full reference.

# --- Required ---
# PostgreSQL connection string. Locally: docker-compose exposes postgres on 5432.
DATABASE_URL=postgresql://nyxtok:nyxtok@localhost:5432/nyxtok
# Absolute path to the on-disk vault (media, transcripts, validation notes).
VAULT_PATH=/data/vault
# Bearer token clients send in the Authorization header. Leave empty to disable auth (dev).
AUTH_TOKEN=
# Base URL of the TikTok MCP server used by the discovery worker.
TIKTOK_MCP_URL=

# --- Groq (transcription + validation) ---
# Free tier covers Whisper + llama-3.3-70b chat. Required when WHISPER_SERVICE=groq.
GROQ_API_KEY=
# Which whisper backend to use: groq (default) | captions.
WHISPER_SERVICE=groq

# --- Discovery worker ---
# Cron expression controlling how often discovery runs (default: every 6 hours).
DISCOVERY_CRON=0 */6 * * *
# Set to 1 to run discovery once and exit (one-shot mode).
DISCOVERY_RUN_NOW=0

# --- Validation pipeline ---
# Whether the LLM claim-validation pass runs on new transcripts.
VALIDATION_ENABLED=true
# Groq model id used for claim extraction / classification / summary.
VALIDATION_MODEL=llama-3.3-70b
# Max claims extracted per video before validation.
MAX_CLAIMS_PER_VIDEO=30
# Per-video validation timeout in seconds.
VALIDATION_TIMEOUT=180

# --- API server ---
# Port the Fastify API listens on.
PORT=3000
# Bind host.
HOST=0.0.0.0
# pino log level.
LOG_LEVEL=info

# --- Web (Next.js) ---
# Public URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:3000
# Internal URL the Next.js server uses to proxy /api/* (defaults to PORT 3000).
NYXTOK_API_URL=http://localhost:3000

# --- Postgres (local docker-compose defaults) ---
POSTGRES_USER=nyxtok
POSTGRES_PASSWORD=nyxtok
POSTGRES_DB=nyxtok
# Set to 1 to log SQL statements.
POSTGRES_DEBUG=0
