{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "node /app/dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "services": [
    {
      "name": "nyxtok-api",
      "source": "packages/api",
      "build": {
        "dockerfilePath": "packages/api/Dockerfile"
      },
      "variables": {
        "PORT": "3000",
        "NODE_ENV": "production",
        "VAULT_PATH": "/data/vault"
      },
      "volumes": [
        {
          "mountPath": "/data"
        }
      ]
    },
    {
      "name": "nyxtok-discovery",
      "source": "packages/discovery",
      "build": {
        "dockerfilePath": "packages/discovery/Dockerfile"
      },
      "variables": {
        "NODE_ENV": "production",
        "VAULT_PATH": "/data/vault",
        "DISCOVERY_RUN_NOW": "0"
      },
      "volumes": [
        {
          "mountPath": "/data"
        }
      ]
    },
    {
      "name": "nyxtok-web",
      "source": "packages/web",
      "build": {
        "dockerfilePath": "packages/web/Dockerfile"
      },
      "variables": {
        "NODE_ENV": "production",
        "PORT": "3001",
        "NEXT_PUBLIC_API_URL": "${{nyxtok-api.RAILWAY_PRIVATE_DOMAIN}}"
      }
    },
    {
      "name": "postgresql",
      "plugin": "postgresql"
    }
  ]
}
